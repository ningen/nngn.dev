---
import TagList from "./TagList.astro";

interface Props {
  title: string;
  description: string;
  href: string;
  date: string;
  dateTime: string;
  tags: readonly string[];
  readingTime?: string;
}

const { title, description, href, date, dateTime, tags, readingTime } = Astro.props;
---

<article class="relative rounded-lg border border-[var(--color-line)] bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-[#b9c5d6] hover:shadow-md">
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-[var(--color-muted)]">
    <time datetime={dateTime}>{date}</time>
    {readingTime ? <span aria-hidden="true">/</span> : null}
    {readingTime ? <span>{readingTime}</span> : null}
  </div>
  <h3 class="mt-3 text-xl font-semibold leading-snug">
    <a class="hover:text-[var(--color-blue)]" href={href}>{title}</a>
  </h3>
  <p class="mt-3 leading-7 text-[var(--color-muted)]">{description}</p>
  <div class="mt-5">
    <TagList tags={tags} linked compact />
  </div>
</article>
