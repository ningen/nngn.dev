---
import SectionHeading from "../components/SectionHeading.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Search" description="Search blog posts on nngn.dev.">
  <SiteHeader />
  <main class="content-grid py-12 md:py-16">
    <div class="max-w-3xl">
      <p class="font-mono text-sm uppercase text-[var(--color-rust)]">Search</p>
      <h1 class="mt-5 text-balance text-5xl font-semibold leading-tight md:text-6xl">Find notes</h1>
      <p class="mt-5 text-lg leading-8 text-[var(--color-muted)]">
        Search across published blog posts, including titles, tags, descriptions, and article text.
      </p>
    </div>

    <section class="mt-10">
      <SectionHeading label="Index" title="Blog search" />

      <div class="mt-6 max-w-3xl">
        <label class="sr-only" for="search-input">Search query</label>
        <div class="search-field">
          <input
            id="search-input"
            type="search"
            autocomplete="off"
            placeholder="Search posts..."
            aria-describedby="search-status"
          />
        </div>
        <p id="search-status" class="mt-3 min-h-6 font-mono text-sm text-[var(--color-muted)]" aria-live="polite">
          Type a word or phrase to search the blog.
        </p>
      </div>

      <div id="search-results" class="mt-8 grid gap-4 md:grid-cols-2"></div>
    </section>
  </main>

  <script is:inline type="module">
    const input = document.querySelector("#search-input");
    const status = document.querySelector("#search-status");
    const resultsList = document.querySelector("#search-results");
    let pagefind;
    let searchRun = 0;
    let searchTimer;

    if (!(input instanceof HTMLInputElement) || !status || !resultsList) {
      throw new Error("Search page markup is missing required elements.");
    }

    const setStatus = (message) => {
      status.textContent = message;
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

    const renderTags = (tags) => {
      if (!tags) return "";

      return tags
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean)
        .map(
          (tag) =>
            `<li><span class="block rounded-md border border-[var(--color-line)] bg-[var(--color-faint)] px-2 py-1 text-xs text-[var(--color-muted)]">${escapeHtml(
              tag,
            )}</span></li>`,
        )
        .join("");
    };

    const renderResult = (result) => {
      const title = result.meta?.title || "Untitled";
      const description = result.meta?.description;
      const date = result.meta?.date;
      const tags = renderTags(result.meta?.tags);
      const excerpt = result.excerpt || (description ? escapeHtml(description) : "");

      return `
        <article class="search-result relative rounded-lg border border-[var(--color-line)] bg-white p-5 shadow-sm transition hover:-translate-y-0.5 hover:border-[#b9c5d6] hover:shadow-md">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-xs text-[var(--color-muted)]">
            ${date ? `<time datetime="${escapeHtml(date)}">${escapeHtml(date)}</time>` : ""}
          </div>
          <h2 class="mt-3 text-xl font-semibold leading-snug">
            <a class="hover:text-[var(--color-blue)]" href="${escapeHtml(result.url)}">${escapeHtml(title)}</a>
          </h2>
          ${excerpt ? `<p class="mt-3 leading-7 text-[var(--color-muted)]">${excerpt}</p>` : ""}
          ${tags ? `<ul class="mt-5 flex flex-wrap gap-2" aria-label="Tags">${tags}</ul>` : ""}
        </article>
      `;
    };

    const loadPagefind = async () => {
      if (pagefind) return pagefind;

      pagefind = await import("/pagefind/pagefind.js");
      await pagefind.init();
      return pagefind;
    };

    const search = async () => {
      const query = input.value.trim();
      const currentRun = ++searchRun;

      if (!query) {
        resultsList.innerHTML = "";
        setStatus("Type a word or phrase to search the blog.");
        return;
      }

      setStatus("Searching...");

      try {
        const pagefindApi = await loadPagefind();
        const searchResults = await pagefindApi.search(query, {
          sort: {
            date: "desc",
          },
        });

        if (currentRun !== searchRun) return;

        const results = await Promise.all(searchResults.results.slice(0, 20).map((result) => result.data()));

        if (currentRun !== searchRun) return;

        if (results.length === 0) {
          resultsList.innerHTML = `
            <div class="rounded-lg border border-dashed border-[var(--color-line)] bg-white p-6 text-[var(--color-muted)] md:col-span-2">
              No posts matched <span class="font-medium text-[var(--color-ink)]">${escapeHtml(query)}</span>.
            </div>
          `;
          setStatus("No results found.");
          return;
        }

        resultsList.innerHTML = results.map(renderResult).join("");
        setStatus(`${results.length} result${results.length === 1 ? "" : "s"} found.`);
      } catch {
        resultsList.innerHTML = `
          <div class="rounded-lg border border-dashed border-[var(--color-line)] bg-white p-6 text-[var(--color-muted)] md:col-span-2">
            Search is available after the site has been built with Pagefind.
          </div>
        `;
        setStatus("Search index could not be loaded.");
      }
    };

    input.addEventListener("focus", () => {
      loadPagefind().catch(() => undefined);
    });
    input.addEventListener("input", () => {
      window.clearTimeout(searchTimer);
      searchTimer = window.setTimeout(search, 150);
    });

    const initialQuery = new URLSearchParams(window.location.search).get("q");
    if (initialQuery) {
      input.value = initialQuery;
      search();
    }
  </script>

  <style>
    .search-field {
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: white;
      box-shadow: 0 1px 2px rgb(15 23 42 / 0.06);
    }

    .search-field:focus-within {
      border-color: var(--color-blue);
      box-shadow: 0 0 0 3px rgb(35 86 216 / 0.12);
    }

    .search-field input {
      width: 100%;
      min-height: 56px;
      border: 0;
      background: transparent;
      color: var(--color-ink);
      font: inherit;
      font-size: 1.05rem;
      padding: 0 1rem;
    }

    .search-field input:focus {
      outline: none;
    }

    .search-result mark {
      border-radius: 4px;
      background: #fde68a;
      color: var(--color-ink);
      padding: 0 0.15em;
    }
  </style>
</BaseLayout>
