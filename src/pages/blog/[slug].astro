---
import { getCollection, render } from "astro:content";
import BlogArticleHeader from "../../components/BlogArticleHeader.astro";
import BlogProse from "../../components/BlogProse.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { estimateReadingMinutes, formatDate, formatDateTime, isPublishedPost } from "../../lib/blog";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter(isPublishedPost);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const publishedAt = formatDate(post.data.publishedAt);
const publishedAtTime = formatDateTime(post.data.publishedAt);
const updatedAt = post.data.updatedAt ? formatDate(post.data.updatedAt) : undefined;
const updatedAtTime = post.data.updatedAt ? formatDateTime(post.data.updatedAt) : undefined;
const readingTime = estimateReadingMinutes(post.body);
const tagsMeta = post.data.tags.join(", ");
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <SiteHeader />
  <main>
    <span style="display: none" data-pagefind-meta={`description:${post.data.description}`}></span>
    <span style="display: none" data-pagefind-meta={`tags:${tagsMeta}`}></span>
    {post.data.tags.map((tag) => <span style="display: none" data-pagefind-filter="tag">{tag}</span>)}
    <time
      style="display: none"
      datetime={publishedAtTime}
      data-pagefind-meta="date[datetime]"
      data-pagefind-sort="date[datetime]"
    >
      {publishedAtTime}
    </time>
    <BlogArticleHeader
      title={post.data.title}
      description={post.data.description}
      date={publishedAt}
      dateTime={publishedAtTime}
      updatedAt={updatedAt}
      updatedAtTime={updatedAtTime}
      readingTime={readingTime}
      tags={post.data.tags}
    />
    <div data-pagefind-body>
      <BlogProse>
        <Content />
      </BlogProse>
    </div>
  </main>
</BaseLayout>
